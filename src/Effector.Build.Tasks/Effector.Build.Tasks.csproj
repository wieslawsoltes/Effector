<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <AssemblyName>Effector.Build.Tasks</AssemblyName>
    <IsPackable>false</IsPackable>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <ImplicitUsings>false</ImplicitUsings>
    <EffectorUseBuiltRuntimeReference Condition="'$(EffectorUseBuiltRuntimeReference)' == '' and '$(DesignTimeBuild)' != 'true'">true</EffectorUseBuiltRuntimeReference>
  </PropertyGroup>

  <ItemGroup Condition="'$(EffectorUseBuiltRuntimeReference)' != 'true'">
    <ProjectReference Include="..\Effector\Effector.csproj"
                      AdditionalProperties="EffectorSkipCustomTargets=true;GeneratePackageOnBuild=false" />
  </ItemGroup>

  <ItemGroup Condition="'$(EffectorUseBuiltRuntimeReference)' == 'true'">
    <ProjectReference Include="..\Effector\Effector.csproj"
                      ReferenceOutputAssembly="false"
                      AdditionalProperties="GeneratePackageOnBuild=false" />
    <Reference Include="Effector">
      <HintPath>..\Effector\bin\$(Configuration)\netstandard2.0\Effector.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Microsoft.Build.Framework" />
    <PackageReference Include="Microsoft.Build.Utilities.Core" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="all" />
    <PackageReference Include="Mono.Cecil" />
    <PackageReference Include="SkiaSharp" />
    <PackageReference Include="System.Reflection.Metadata" />
  </ItemGroup>
</Project>
