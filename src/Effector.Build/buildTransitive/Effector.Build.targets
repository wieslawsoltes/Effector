<Project>
  <PropertyGroup>
    <_EffectorPackagedTaskAssemblyPath Condition="'$(_EffectorPackagedTaskAssemblyPath)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)Effector.Build.Tasks.dll'))</_EffectorPackagedTaskAssemblyPath>
    <_EffectorLocalTaskProjectPath Condition="'$(_EffectorLocalTaskProjectPath)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\Effector.Build.Tasks\Effector.Build.Tasks.csproj'))</_EffectorLocalTaskProjectPath>
    <_EffectorLocalTaskAssemblyPath Condition="'$(_EffectorLocalTaskAssemblyPath)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\Effector.Build.Tasks\bin\$(Configuration)\netstandard2.0\Effector.Build.Tasks.dll'))</_EffectorLocalTaskAssemblyPath>
    <_EffectorTaskAssemblyPath Condition="'$(_EffectorTaskAssemblyPath)' == '' and Exists('$(_EffectorPackagedTaskAssemblyPath)')">$(_EffectorPackagedTaskAssemblyPath)</_EffectorTaskAssemblyPath>
    <_EffectorTaskAssemblyPath Condition="'$(_EffectorTaskAssemblyPath)' == '' and Exists('$(_EffectorLocalTaskProjectPath)')">$(_EffectorLocalTaskAssemblyPath)</_EffectorTaskAssemblyPath>
  </PropertyGroup>

  <UsingTask TaskName="Effector.Build.Tasks.WeaveSkiaEffectsTask"
             AssemblyFile="$(_EffectorTaskAssemblyPath)"
             Condition="'$(EffectorEnabled)' == 'true' and '$(_EffectorTaskAssemblyPath)' != ''" />
  <UsingTask TaskName="Effector.Build.Tasks.PatchAvaloniaAssembliesTask"
             AssemblyFile="$(_EffectorTaskAssemblyPath)"
             Condition="'$(EffectorEnabled)' == 'true' and '$(_EffectorTaskAssemblyPath)' != ''" />

  <Target Name="Effector_BuildLocalTask"
          Condition="'$(EffectorEnabled)' == 'true' and !Exists('$(_EffectorPackagedTaskAssemblyPath)') and Exists('$(_EffectorLocalTaskProjectPath)')">
    <MSBuild Projects="$(_EffectorLocalTaskProjectPath)"
             Targets="Restore"
             BuildInParallel="false"
             RemoveProperties="TargetFramework;TargetFrameworks;PublishAot;RuntimeIdentifier;SelfContained;PublishTrimmed;PublishSingleFile;PublishReadyToRun;NoBuild"
             Properties="Configuration=$(Configuration);TargetFramework=netstandard2.0;GeneratePackageOnBuild=false;DesignTimeBuild=false;BuildingProject=false;NoBuild=false" />
    <MSBuild Projects="$(_EffectorLocalTaskProjectPath)"
             Targets="Build"
             BuildInParallel="false"
             RemoveProperties="TargetFramework;TargetFrameworks;PublishAot;RuntimeIdentifier;SelfContained;PublishTrimmed;PublishSingleFile;PublishReadyToRun;NoBuild"
             Properties="Configuration=$(Configuration);TargetFramework=netstandard2.0;GeneratePackageOnBuild=false;DesignTimeBuild=false;BuildingProject=false;NoBuild=false" />
  </Target>

  <Target Name="Effector_WeaveSkiaEffects"
          AfterTargets="CoreCompile"
          BeforeTargets="CopyFilesToOutputDirectory"
          DependsOnTargets="Effector_BuildLocalTask"
          Condition="'$(EffectorEnabled)' == 'true' and '$(DesignTimeBuild)' != 'true' and '@(IntermediateAssembly)' != ''">
    <Error Condition="!Exists('$(_EffectorTaskAssemblyPath)')"
           Text="[Effector.Build] Task assembly was not found at '$(_EffectorTaskAssemblyPath)'." />

    <WeaveSkiaEffectsTask AssemblyPath="@(IntermediateAssembly->'%(FullPath)')"
                          Strict="$(EffectorStrict)"
                          Verbose="$(EffectorVerbose)"
                          ProjectDirectory="$(MSBuildProjectDirectory)"
                          ReferencePaths="@(ReferencePath);@(ReferenceCopyLocalPaths)"
                          SupportedAvaloniaVersion="$(EffectorSupportedAvaloniaVersion)" />
  </Target>

  <Target Name="Effector_PatchAvaloniaOutputAssemblies"
          AfterTargets="CopyFilesToOutputDirectory"
          DependsOnTargets="Effector_BuildLocalTask"
          Condition="'$(EffectorEnabled)' == 'true' and '$(DesignTimeBuild)' != 'true' and '$(TargetDir)' != ''">
    <PatchAvaloniaAssembliesTask AvaloniaBaseAssemblyPath="$([System.IO.Path]::Combine('$(TargetDir)', 'Avalonia.Base.dll'))"
                                 AvaloniaSkiaAssemblyPath="$([System.IO.Path]::Combine('$(TargetDir)', 'Avalonia.Skia.dll'))"
                                 Strict="$(EffectorStrict)"
                                 Verbose="$(EffectorVerbose)"
                                 SupportedAvaloniaVersion="$(EffectorSupportedAvaloniaVersion)" />
  </Target>

  <Target Name="Effector_PatchAvaloniaAotCompileAssemblies"
          AfterTargets="ComputeIlcCompileInputs"
          BeforeTargets="WriteIlcRspFileForCompilation"
          DependsOnTargets="Effector_BuildLocalTask"
          Condition="'$(EffectorEnabled)' == 'true' and '$(PublishAot)' == 'true' and '$(DesignTimeBuild)' != 'true'">
    <PropertyGroup>
      <_EffectorAotPatchedAssemblyDir>$([System.IO.Path]::Combine('$(IntermediateOutputPath)', 'effector-aot-patched'))</_EffectorAotPatchedAssemblyDir>
    </PropertyGroup>

    <ItemGroup>
      <_EffectorAvaloniaIlcReference Include="@(IlcReference)"
                                     Condition="'%(Filename)' == 'Avalonia.Base' or '%(Filename)' == 'Avalonia.Skia'" />
      <_EffectorPatchedIlcReference Include="@(_EffectorAvaloniaIlcReference->'$(_EffectorAotPatchedAssemblyDir)\%(Filename)%(Extension)')" />
    </ItemGroup>

    <MakeDir Directories="$(_EffectorAotPatchedAssemblyDir)"
             Condition="'@(_EffectorAvaloniaIlcReference)' != ''" />

    <Copy SourceFiles="@(_EffectorAvaloniaIlcReference)"
          DestinationFiles="@(_EffectorPatchedIlcReference)"
          SkipUnchangedFiles="false"
          OverwriteReadOnlyFiles="true"
          Condition="'@(_EffectorAvaloniaIlcReference)' != ''" />

    <PatchAvaloniaAssembliesTask AvaloniaBaseAssemblyPath="$([System.IO.Path]::Combine('$(_EffectorAotPatchedAssemblyDir)', 'Avalonia.Base.dll'))"
                                 AvaloniaSkiaAssemblyPath="$([System.IO.Path]::Combine('$(_EffectorAotPatchedAssemblyDir)', 'Avalonia.Skia.dll'))"
                                 Strict="$(EffectorStrict)"
                                 Verbose="$(EffectorVerbose)"
                                 SupportedAvaloniaVersion="$(EffectorSupportedAvaloniaVersion)"
                                 Condition="'@(_EffectorAvaloniaIlcReference)' != ''" />

    <ItemGroup Condition="'@(_EffectorAvaloniaIlcReference)' != ''">
      <IlcReference Remove="@(_EffectorAvaloniaIlcReference)" />
      <IlcReference Include="@(_EffectorPatchedIlcReference)" />
    </ItemGroup>
  </Target>

  <Target Name="Effector_PatchAvaloniaPublishAssemblies"
          AfterTargets="Publish"
          DependsOnTargets="Effector_BuildLocalTask"
          Condition="'$(EffectorEnabled)' == 'true' and '$(DesignTimeBuild)' != 'true' and '$(PublishDir)' != ''">
    <PatchAvaloniaAssembliesTask AvaloniaBaseAssemblyPath="$([System.IO.Path]::Combine('$(PublishDir)', 'Avalonia.Base.dll'))"
                                 AvaloniaSkiaAssemblyPath="$([System.IO.Path]::Combine('$(PublishDir)', 'Avalonia.Skia.dll'))"
                                 Strict="$(EffectorStrict)"
                                 Verbose="$(EffectorVerbose)"
                                 SupportedAvaloniaVersion="$(EffectorSupportedAvaloniaVersion)" />
  </Target>
</Project>
