<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework Condition="'$(PublishAot)' == 'true'">net8.0</TargetFramework>
    <TargetFrameworks Condition="'$(PublishAot)' != 'true' and '$(TargetFramework)' == ''">net8.0;netstandard2.0</TargetFrameworks>
    <AssemblyName>Effector.FilterEffects</AssemblyName>
    <PackageId>Effector.FilterEffects</PackageId>
    <Title>Effector.FilterEffects</Title>
    <Description>SVG-inspired filter effect graph primitives for Effector.</Description>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <GeneratePackageOnBuild Condition="'$(PublishAot)' == 'true'">false</GeneratePackageOnBuild>
    <IsPackable>true</IsPackable>
    <ProduceReferenceAssembly>false</ProduceReferenceAssembly>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Effector\Effector.csproj" />
    <PackageReference Include="Avalonia" />
    <PackageReference Include="SkiaSharp" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <Import Project="..\Effector.Build\buildTransitive\Effector.Build.props" />
  <Import Project="..\Effector.Build\buildTransitive\Effector.Build.targets" />
</Project>
